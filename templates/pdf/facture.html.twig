{% extends 'pdf/_base.html.twig' %}

{% block title %}Facture {{ facture.numero }}{% endblock %}

{% block page_head_left %}Facture n° {{ facture.numero }}{% endblock %}

{% block content %}

    {% set client = facture.client %}

    {# ===== TITRE + CLIENT ===== #}
    <div class="doc-title-row">
        <div class="doc-title-cell">
            <div class="doc-title-main">Facture n° {{ facture.numero }}</div>
            <div class="doc-title-sub">
                Date de facturation : {{ facture.dateFacture ? facture.dateFacture|date('d/m/Y') : 'N/A' }}<br>
                {% if facture.chantier %}
                    {{ facture.chantier.nom }}{% if facture.chantier.villeChantier %} — {{ facture.chantier.villeChantier }}{% endif %}
                {% endif %}
                {% if facture.description %}<br>{{ facture.description }}{% endif %}
            </div>
        </div>
        {% if client %}
        <div class="doc-client-cell">
            <div class="client-name">{{ client.raisonSocial|upper }}</div>
            <div class="client-addr">
                {% if client.adresse %}{{ client.adresse }}<br>{% endif %}
                {% if client.codePostal or client.ville %}{{ client.codePostal }} {{ client.ville }}<br>{% endif %}
                France
            </div>
        </div>
        {% endif %}
    </div>

    {# ===== LIGNES ===== #}
    <table class="details-table">
        <thead>
            <tr>
                <th style="width: 46%;">Description</th>
                <th style="width: 10%;" class="text-right">Quantité</th>
                <th style="width: 10%;" class="text-center">Unité</th>
                <th style="width: 17%;" class="text-right">Prix unitaire</th>
                <th style="width: 17%;" class="text-right">Total HT</th>
            </tr>
        </thead>
        <tbody>
            {% set totalHT = 0 %}
            {% set tvaMap = {} %}

            {% for ligne in facture.lignes %}
                {% set ligneHt = (ligne.quantite ?? 0) * (ligne.prixUnitaireHt ?? 0) %}
                {% set tvaKey = ligne.tauxTva ?: 20 %}
                {% set totalHT = totalHT + ligneHt %}
                {% if attribute(tvaMap, tvaKey) is defined %}
                    {% set tvaMap = tvaMap|merge({(tvaKey): attribute(tvaMap, tvaKey) + ligneHt}) %}
                {% else %}
                    {% set tvaMap = tvaMap|merge({(tvaKey): ligneHt}) %}
                {% endif %}
                <tr>
                    <td class="cell-desc">{{ ligne.designation }}</td>
                    <td class="text-right cell-num">{{ ligne.quantite }}</td>
                    <td class="text-center">unité</td>
                    <td class="text-right cell-num">{{ ligne.prixUnitaireHt ? ligne.prixUnitaireHt|number_format(2, ',', ' ') ~ ' € HT' : '' }}</td>
                    <td class="text-right cell-num">{{ ligneHt > 0 ? ligneHt|number_format(2, ',', ' ') ~ ' €' : '' }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" style="text-align: center; padding: 20px; color: #aaa;">
                        Aucune ligne dans cette facture
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {# ===== TOTAUX ===== #}
    {% set totalTVA = 0 %}
    <div class="totals-wrap">
        <div class="totals-spacer"></div>
        <div class="totals-box">
            <div class="total-row">
                <span class="total-label">Total HT</span>
                <span class="total-value">{{ totalHT|number_format(2, ',', ' ') }} €</span>
            </div>
            {% for tvaRate, base in tvaMap %}
                {% set tvaAmount = base * (tvaRate / 100) %}
                {% set totalTVA = totalTVA + tvaAmount %}
                <div class="total-row">
                    <span class="total-label">TVA {{ tvaRate }} %</span>
                    <span class="total-value">{{ tvaAmount|number_format(2, ',', ' ') }} €</span>
                </div>
            {% endfor %}
            {% if tvaMap is empty %}
                {% set totalTVA = totalHT * 0.20 %}
                <div class="total-row">
                    <span class="total-label">TVA 20 %</span>
                    <span class="total-value">{{ totalTVA|number_format(2, ',', ' ') }} €</span>
                </div>
            {% endif %}
            <div class="total-row total-ttc">
                <span class="total-label">Total TTC à régler</span>
                <span class="total-value">{{ (totalHT + totalTVA)|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>
    </div>

    {# ===== MERCI + CONDITIONS ===== #}
    <div class="thanks">Merci pour votre confiance !</div>
    <div class="payment-terms">
        <p>La facture est payable à réception.</p>
        <p>Des pénalités correspondant au taux directeur de la BCE (la Banque Centrale Européenne), majoré de 10 points seront applicables en l'absence ou en cas de retard de paiement.</p>
        <p>Les pénalités de retard sont exigibles sans qu'un rappel soit nécessaire.</p>
        <p>Une indemnité forfaitaire de 40 € pour frais de recouvrement sera appliquée en cas de retard de paiement conformément aux articles L 441-3 et L 441-6 du code de commerce.</p>
        <p>Pas d'escompte en cas de paiement anticipé.</p>
        {% if entreprise.iban %}
            <p>{{ entreprise.iban }}{% if entreprise.bic %} · BIC {{ entreprise.bic }}{% endif %}</p>
        {% endif %}
    </div>

{% endblock %}
