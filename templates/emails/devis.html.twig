{% extends 'emails/_base.html.twig' %}

{% block title %}Votre devis {{ devis.numero }}{% endblock %}

{% block content %}
    <p>Bonjour{% if devis.prenomInterlocuteur or devis.nomInterlocuteur %} {{ devis.prenomInterlocuteur }} {{ devis.nomInterlocuteur }}{% endif %},</p>

    <p>
        Veuillez trouver ci-joint le devis&nbsp;<strong>{{ devis.numero }}</strong>
        {% if devis.titre %} — {{ devis.titre }}{% endif %}.
    </p>

    {% if messageIntro %}
        <p>{{ messageIntro|nl2br }}</p>
    {% endif %}

    <p>
        Pour toute question, vous pouvez répondre directement à cet email.
    </p>

    <p>
        Cordialement,<br>
        {{ entreprise.nom|default('HK Entreprise') }}
    </p>
{% endblock %}
