<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Document{% endblock %}</title>
    <style>
        @page {
            margin: 72px 72px 72px 72px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            font-size: 11.5px;
            line-height: 1.6;
            color: #222;
            font-weight: 300;
        }

        /* ===== PAGE HEADER (petit, haut de page, sur chaque page via fixed) ===== */
        .page-head {
            position: fixed;
            top: -24px;
            left: 0;
            right: 0;
            display: table;
            width: 100%;
            font-size: 9px;
            color: #6b6b6b;
        }
        .page-head-left, .page-head-right {
            display: table-cell;
            vertical-align: top;
        }
        .page-head-right { text-align: right; }

        /* ===== LOGO + NOM ENTREPRISE (uniquement page 1) ===== */
        .brand-block {
            margin-bottom: 26px;
        }
        .company-logo {
            max-width: 150px;
            max-height: 72px;
            margin-bottom: 10px;
        }
        .company-name {
            font-size: 16px;
            font-weight: 700;
            color: #1B7A8A;
            letter-spacing: 0.3px;
        }

        /* ===== TITRE + CLIENT (deux colonnes) ===== */
        .doc-title-row {
            display: table;
            width: 100%;
            margin-bottom: 34px;
        }
        .doc-title-cell, .doc-client-cell {
            display: table-cell;
            vertical-align: top;
            width: 55%;
        }
        .doc-client-cell { width: 45%; text-align: right; }

        .doc-title-main {
            font-size: 19px;
            font-weight: 700;
            color: #111;
            letter-spacing: -0.2px;
            margin-bottom: 8px;
        }
        .doc-title-sub {
            font-size: 11px;
            color: #555;
            line-height: 1.7;
        }
        .doc-title-sub strong {
            color: #222;
            font-weight: 500;
        }

        .client-name {
            font-size: 13.5px;
            font-weight: 700;
            color: #111;
            margin-bottom: 6px;
            letter-spacing: 0.2px;
        }
        .client-addr {
            font-size: 11px;
            color: #555;
            line-height: 1.7;
        }

        /* ===== TABLEAU LIGNES ===== */
        .details-table {
            width: 100%;
            border-collapse: collapse;
            margin: 14px 0 18px;
            font-size: 11px;
        }
        .details-table thead tr {
            border-bottom: 1px solid #d9d9d9;
        }
        .details-table th {
            padding: 12px 8px;
            text-align: left;
            font-weight: 600;
            font-size: 9px;
            letter-spacing: 1.4px;
            text-transform: uppercase;
            color: #777;
        }
        .details-table td {
            padding: 13px 8px;
            border-bottom: 1px solid #f0f0f0;
            vertical-align: top;
            color: #222;
            font-weight: 300;
            font-size: 11px;
        }
        .details-table tr.bloc-row td {
            background: transparent;
            font-weight: 700;
            color: #1B7A8A;
            padding: 14px 6px 6px;
            font-size: 10px;
            letter-spacing: 0.3px;
            border-bottom: 1px solid #e4e4e4;
            text-transform: uppercase;
        }
        .details-table tr.comment-row td {
            color: #777;
            font-style: italic;
            padding: 6px 6px;
            font-size: 9px;
            border-bottom: 1px solid #f5f5f5;
        }
        .details-table .cell-num { font-variant-numeric: tabular-nums; }
        .details-table .cell-desc { color: #222; font-weight: 400; }
        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* ===== TOTAUX (right-aligned, sans boîte) ===== */
        .totals-wrap {
            display: table;
            width: 100%;
            margin-top: 8px;
            page-break-inside: avoid;
        }
        .totals-spacer { display: table-cell; width: 55%; }
        .totals-box {
            display: table-cell;
            width: 45%;
            vertical-align: top;
            font-size: 11.5px;
        }
        .total-row {
            display: table;
            width: 100%;
            padding: 8px 0;
        }
        .total-label {
            display: table-cell;
            text-align: right;
            color: #555;
            padding-right: 24px;
            font-weight: 300;
        }
        .total-value {
            display: table-cell;
            text-align: right;
            width: 36%;
            color: #222;
            font-weight: 500;
            font-variant-numeric: tabular-nums;
        }
        .total-ttc {
            border-top: 2px solid #222;
            padding-top: 12px;
            margin-top: 8px;
        }
        .total-ttc .total-label {
            font-weight: 600;
            color: #111;
            font-size: 12.5px;
        }
        .total-ttc .total-value {
            font-weight: 700;
            color: #111;
            font-size: 15px;
        }

        /* ===== MERCI / CONDITIONS ===== */
        .thanks {
            margin-top: 50px;
            font-size: 15px;
            font-weight: 700;
            color: #111;
        }
        .payment-terms {
            margin-top: 14px;
            font-size: 10.5px;
            color: #555;
            line-height: 1.8;
        }
        .payment-terms p { margin-bottom: 5px; }

        /* ===== FOOTER INLINE (en fin de contenu, pas fixed) ===== */
        .footer-inline {
            margin-top: 60px;
            padding-top: 16px;
            border-top: 1px solid #e4e4e4;
            font-size: 9.5px;
            color: #777;
            line-height: 1.75;
            page-break-inside: avoid;
        }
        .footer-inline .company-footer-name {
            font-weight: 700;
            color: #222;
            margin-bottom: 3px;
            font-size: 10.5px;
        }
        .footer-inline .mentions { font-size: 9px; color: #888; margin-top: 4px; }

        /* ===== SIGNATURE ===== */
        .signature-section {
            margin-top: 40px;
            display: table;
            width: 100%;
        }
        .signature-left {
            display: table-cell;
            width: 55%;
        }
        .signature-right {
            display: table-cell;
            width: 45%;
            text-align: right;
        }
        .signature-box {
            display: inline-block;
            text-align: left;
            min-width: 200px;
            padding: 12px 14px 32px;
            border: 1px dashed #cbcbcb;
            border-radius: 3px;
            font-size: 9px;
            color: #888;
        }
        .signature-box .sig-title {
            font-size: 10px;
            font-weight: 600;
            color: #111;
            margin-bottom: 2px;
        }

        /* ===== UTILS ===== */
        .page-break { page-break-after: always; }
    </style>
</head>
<body>

    {# ===== LOGO + NOM (page 1) ===== #}
    <div class="brand-block">
        {% if entreprise.logo %}
            <img src="{{ entreprise.logo }}" class="company-logo" alt="{{ entreprise.nom }}">
        {% endif %}
        <div class="company-name">{{ entreprise.nom }}</div>
    </div>

    {# ===== CORPS DU DOCUMENT ===== #}
    {% block content %}{% endblock %}

    {# ===== MENTIONS LÉGALES EN FIN DE DOCUMENT ===== #}
    <div class="footer-inline">
        <div class="company-footer-name">{{ entreprise.nom }}</div>
        {% if entreprise.adresse %}Siège social : {{ entreprise.adresse }}{% if entreprise.codePostal %}, {{ entreprise.codePostal }} {{ entreprise.ville }}{% endif %}<br>{% endif %}
        {% if entreprise.formeJuridique %}{{ entreprise.formeJuridique }}{% if entreprise.capital %} au capital de {{ entreprise.capital }}{% endif %}<br>{% endif %}
        {% if entreprise.siret %}N° SIRET : {{ entreprise.siret }}{% endif %}
        {% if entreprise.rcs and entreprise.villeRcs %} / RCS {{ entreprise.villeRcs|upper }} {{ entreprise.rcs }}{% endif %}
        {% if entreprise.codeNaf %} / APE : {{ entreprise.codeNaf }}{% endif %}
        {% if entreprise.tvaIntracommunautaire %}<br>N° TVA intracommunautaire : {{ entreprise.tvaIntracommunautaire }}{% endif %}
        {% if entreprise.email %}<br>{{ entreprise.email }}{% endif %}
        {% if entreprise.mentionsLegales %}<div class="mentions">{{ entreprise.mentionsLegales|raw }}</div>{% endif %}
    </div>

</body>
</html>
