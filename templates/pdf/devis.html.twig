{% extends 'pdf/_base.html.twig' %}

{% block title %}Devis {{ devis.numero }}{% endblock %}

{% block page_head_left %}Devis n° {{ devis.numero }}{% endblock %}

{% block content %}

    {% set client = devis.chantier ? devis.chantier.client : null %}

    {# ===== TITRE + CLIENT ===== #}
    <div class="doc-title-row">
        <div class="doc-title-cell">
            <div class="doc-title-main">Devis n° {{ devis.numero }}</div>
            <div class="doc-title-sub">
                Date d'émission : {{ devis.dateCreation ? devis.dateCreation|date('d/m/Y') : 'N/A' }}<br>
                {% if devis.chantier %}
                    Chantier : {{ devis.chantier.nom }}{% if devis.chantier.villeChantier %} — {{ devis.chantier.villeChantier }}{% endif %}
                {% endif %}
                {% if devis.titre %}<br>{{ devis.titre }}{% endif %}
            </div>
        </div>
        {% if client %}
        <div class="doc-client-cell">
            <div class="client-name">{{ client.raisonSocial|upper }}</div>
            <div class="client-addr">
                {% if client.adresse %}{{ client.adresse }}<br>{% endif %}
                {% if client.codePostal or client.ville %}{{ client.codePostal }} {{ client.ville }}<br>{% endif %}
                {% if client.telephone %}{{ client.telephone }}<br>{% endif %}
                {% if client.email %}{{ client.email }}{% endif %}
            </div>
        </div>
        {% endif %}
    </div>

    {# ===== LIGNES DE DEVIS ===== #}
    <table class="details-table">
        <thead>
            <tr>
                <th style="width: 46%;">Description</th>
                <th style="width: 10%;" class="text-right">Quantité</th>
                <th style="width: 10%;" class="text-center">Unité</th>
                <th style="width: 17%;" class="text-right">Prix unitaire</th>
                <th style="width: 17%;" class="text-right">Total HT</th>
            </tr>
        </thead>
        <tbody>
            {% set totalHT = 0 %}
            {% set tvaMap = {} %}

            {% for detail in details %}
                {% if detail.lineType == 'BH' %}
                    <tr class="bloc-row">
                        <td colspan="5">{{ detail.designation }}</td>
                    </tr>
                {% elseif detail.lineType == 'RL' %}
                    {% set lineTotal = (detail.quantite|default(0)) * (detail.prixUnitaire|default(0)) %}
                    {% set totalHT = totalHT + lineTotal %}
                    {% if detail.tva %}
                        {% set tvaKey = detail.tva %}
                        {% if attribute(tvaMap, tvaKey) is defined %}
                            {% set tvaMap = tvaMap|merge({(tvaKey): attribute(tvaMap, tvaKey) + lineTotal}) %}
                        {% else %}
                            {% set tvaMap = tvaMap|merge({(tvaKey): lineTotal}) %}
                        {% endif %}
                    {% endif %}
                    <tr>
                        <td class="cell-desc">
                            {% if detail.reference %}<span style="color:#999;font-size:8.5px;">[{{ detail.reference }}]</span> {% endif %}
                            {{ detail.designation }}
                        </td>
                        <td class="text-right cell-num">{{ detail.quantite }}</td>
                        <td class="text-center">{{ detail.unite ?: '' }}</td>
                        <td class="text-right cell-num">{{ detail.prixUnitaire ? detail.prixUnitaire|number_format(2, ',', ' ') ~ ' €' : '' }}</td>
                        <td class="text-right cell-num">{{ lineTotal > 0 ? lineTotal|number_format(2, ',', ' ') ~ ' €' : '' }}</td>
                    </tr>
                {% elseif detail.lineType == 'C' %}
                    <tr class="comment-row">
                        <td colspan="5">{{ detail.designation }}</td>
                    </tr>
                {% endif %}
            {% else %}
                <tr>
                    <td colspan="5" style="text-align: center; padding: 20px; color: #aaa;">
                        Aucune ligne dans ce devis
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {# ===== TOTAUX ===== #}
    {% set totalTVA = 0 %}
    <div class="totals-wrap">
        <div class="totals-spacer"></div>
        <div class="totals-box">
            <div class="total-row">
                <span class="total-label">Total HT</span>
                <span class="total-value">{{ totalHT|number_format(2, ',', ' ') }} €</span>
            </div>
            {% for tvaRate, base in tvaMap %}
                {% set tvaAmount = base * (tvaRate / 100) %}
                {% set totalTVA = totalTVA + tvaAmount %}
                <div class="total-row">
                    <span class="total-label">TVA {{ tvaRate }} %</span>
                    <span class="total-value">{{ tvaAmount|number_format(2, ',', ' ') }} €</span>
                </div>
            {% endfor %}
            {% if tvaMap is empty %}
                {% set totalTVA = totalHT * 0.20 %}
                <div class="total-row">
                    <span class="total-label">TVA 20 %</span>
                    <span class="total-value">{{ totalTVA|number_format(2, ',', ' ') }} €</span>
                </div>
            {% endif %}
            <div class="total-row total-ttc">
                <span class="total-label">Total TTC</span>
                <span class="total-value">{{ (totalHT + totalTVA)|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>
    </div>

    {# ===== MERCI + CONDITIONS ===== #}
    <div class="thanks">Merci pour votre confiance !</div>
    <div class="payment-terms">
        <p>
            <strong style="color:#222;">Validité de l'offre :</strong>
            {{ entreprise.validiteOffre ?: '30 jours à compter de la date d\'émission' }}
        </p>
        <p>
            <strong style="color:#222;">Délai d'exécution :</strong>
            {{ entreprise.delaiExecution ?: 'À convenir avec le client' }}
        </p>
        <p>
            <strong style="color:#222;">Mode de règlement :</strong>
            {{ entreprise.modeReglement ?: 'Virement bancaire' }}
            {% if entreprise.iban %} — IBAN : {{ entreprise.iban }}{% endif %}
            {% if entreprise.bic %} — BIC : {{ entreprise.bic }}{% endif %}
        </p>
    </div>

    {# ===== SIGNATURE ===== #}
    <div class="signature-section">
        <div class="signature-left"></div>
        <div class="signature-right">
            <div class="signature-box">
                <div class="sig-title">Bon pour accord</div>
                Date et signature du client<br>
                <span style="font-size:8px;">(précédé de « Lu et approuvé »)</span>
            </div>
        </div>
    </div>

{% endblock %}
