{% extends 'emails/_base.html.twig' %}

{% block title %}Bienvenue sur {{ entreprise.nom|default('HK Entreprise') }}{% endblock %}

{% block content %}
    <p>
        Bonjour
        {%- if user.prenom or user.nom %} {{ user.prenom }} {{ user.nom }}{% elseif user.email %} {{ user.email }}{% endif %},
    </p>

    <p>
        Un compte vient d'être créé pour vous sur l'espace {{ entreprise.nom|default('HK Entreprise') }}.
        Vous trouverez ci-dessous vos identifiants d'accès.
    </p>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%"
        style="border:1px solid #e2e8f0;border-radius:6px;margin:16px 0;">
        <tr>
            <td style="padding:10px 14px;background-color:#f1f5f9;color:#334155;font-size:13px;width:45%;border-bottom:1px solid #e2e8f0;">
                Votre email de connexion
            </td>
            <td style="padding:10px 14px;color:#0f172a;font-size:13px;font-family:monospace;border-bottom:1px solid #e2e8f0;">
                {{ user.email ?? user.username }}
            </td>
        </tr>
        <tr>
            <td style="padding:10px 14px;background-color:#f1f5f9;color:#334155;font-size:13px;border-bottom:1px solid #e2e8f0;">
                Votre mot de passe temporaire
            </td>
            <td style="padding:10px 14px;color:#0f172a;font-size:13px;font-family:monospace;border-bottom:1px solid #e2e8f0;">
                {{ plainPassword }}
            </td>
        </tr>
        <tr>
            <td style="padding:10px 14px;background-color:#f1f5f9;color:#334155;font-size:13px;">
                URL d'accès
            </td>
            <td style="padding:10px 14px;font-size:13px;">
                <a href="{{ loginUrl }}" style="color:#1B7A8A;">{{ loginUrl }}</a>
            </td>
        </tr>
    </table>

    <p style="color:#475569;font-size:13px;">
        Nous vous recommandons de changer votre mot de passe à la première connexion, via votre profil.
    </p>

    <p>
        Cordialement,<br>
        {{ entreprise.nom|default('HK Entreprise') }}
    </p>
{% endblock %}
