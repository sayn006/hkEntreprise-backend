<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Document{% endblock %}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            font-size: 10px;
            line-height: 1.4;
            color: #333;
            padding: 20px;
        }

        /* ===== HEADER ===== */
        .header {
            display: table;
            width: 100%;
            margin-bottom: 20px;
            border-bottom: 3px solid #1a237e;
            padding-bottom: 15px;
        }
        .header-left, .header-right {
            display: table-cell;
            vertical-align: top;
        }
        .header-left { width: 55%; }
        .header-right { width: 45%; text-align: right; }

        .company-logo { max-width: 160px; max-height: 70px; margin-bottom: 8px; }

        .company-name {
            font-size: 18px;
            font-weight: bold;
            color: #1a237e;
            margin-bottom: 4px;
        }
        .company-info {
            font-size: 9px;
            color: #555;
            line-height: 1.6;
        }

        /* ===== TITRE DOCUMENT ===== */
        .document-title {
            background: linear-gradient(135deg, #1a237e 0%, #283593 100%);
            color: white;
            padding: 14px 18px;
            margin: 18px 0;
            border-radius: 4px;
        }
        .document-title h1 {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 6px;
        }
        .document-meta {
            display: table;
            width: 100%;
        }
        .document-meta span {
            display: table-cell;
            font-size: 9px;
            opacity: 0.9;
        }

        /* ===== CLIENT / DESTINATAIRE ===== */
        .recipient-block {
            float: right;
            background: #f5f5f5;
            border: 1px solid #ddd;
            border-radius: 4px;
            padding: 10px 14px;
            min-width: 220px;
            margin-bottom: 15px;
        }
        .recipient-label {
            font-size: 8px;
            text-transform: uppercase;
            color: #888;
            margin-bottom: 4px;
            letter-spacing: 0.5px;
        }
        .recipient-name {
            font-weight: bold;
            font-size: 11px;
            color: #333;
        }
        .recipient-info {
            font-size: 9px;
            color: #555;
            margin-top: 2px;
            line-height: 1.5;
        }
        .clearfix::after { content: ''; display: table; clear: both; }

        /* ===== SECTIONS INFO ===== */
        .info-section {
            background: #fff;
            border: 1px solid #e0e0e0;
            border-radius: 4px;
            padding: 10px 12px;
            margin-bottom: 14px;
        }
        .info-section-title {
            font-size: 8px;
            text-transform: uppercase;
            color: #888;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
            border-bottom: 1px solid #eee;
            padding-bottom: 4px;
        }

        /* ===== TABLEAU LIGNES ===== */
        .details-table {
            width: 100%;
            border-collapse: collapse;
            margin: 14px 0;
            font-size: 9px;
        }
        .details-table thead tr {
            background: #1a237e;
            color: white;
        }
        .details-table th {
            padding: 7px 6px;
            text-align: left;
            font-weight: 600;
            font-size: 8.5px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }
        .details-table td {
            padding: 5px 6px;
            border-bottom: 1px solid #f0f0f0;
            vertical-align: top;
        }
        .details-table tr:nth-child(even) td { background: #fafafa; }
        .details-table tr.bloc-row td {
            background: #cfe2ff;
            font-weight: bold;
            font-size: 9.5px;
            color: #084298;
            padding: 6px;
        }
        .details-table tr.hors-bloc td { background: #fff3cd; }
        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* ===== TOTAUX ===== */
        .totals-section {
            display: table;
            width: 100%;
            margin-top: 10px;
        }
        .totals-spacer { display: table-cell; width: 55%; }
        .totals-box {
            display: table-cell;
            width: 45%;
            vertical-align: top;
        }
        .total-row {
            display: table;
            width: 100%;
            border-bottom: 1px solid #eee;
            padding: 5px 0;
        }
        .total-label {
            display: table-cell;
            font-size: 9px;
            color: #555;
        }
        .total-value {
            display: table-cell;
            text-align: right;
            font-weight: 600;
            font-size: 10px;
        }
        .total-ttc {
            background: #1a237e;
            color: white;
            padding: 8px 6px;
            border-radius: 3px;
            margin-top: 4px;
        }
        .total-ttc .total-label, .total-ttc .total-value {
            color: white;
            font-size: 11px;
            font-weight: bold;
        }

        /* ===== CONDITIONS & SIGNATURE ===== */
        .conditions-section {
            display: table;
            width: 100%;
            margin-top: 20px;
            border: 1px solid #e0e0e0;
            border-radius: 4px;
            padding: 12px;
        }
        .conditions-left { display: table-cell; width: 55%; vertical-align: top; font-size: 9px; line-height: 1.7; }
        .conditions-right { display: table-cell; width: 45%; text-align: center; vertical-align: top; }
        .signature-box {
            border: 1px dashed #ccc;
            padding: 25px 20px;
            display: inline-block;
            min-width: 160px;
        }
        .signature-box p { font-size: 9px; color: #888; margin-bottom: 4px; }

        /* ===== FOOTER ===== */
        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            border-top: 1px solid #ddd;
            padding: 8px 20px;
            font-size: 8px;
            color: #888;
            background: white;
        }
        .footer-iban { margin-bottom: 3px; }
        .mentions-legales { font-size: 7.5px; color: #aaa; }

        /* ===== PAGE BREAK ===== */
        .page-break { page-break-after: always; }
    </style>
</head>
<body>

    {# ===== HEADER SOCIÉTÉ ===== #}
    <div class="header">
        <div class="header-left">
            {% if entreprise.logo %}
                <img src="{{ entreprise.logo }}" class="company-logo" alt="Logo">
            {% endif %}
            <div class="company-name">{{ entreprise.nom }}</div>
            <div class="company-info">
                {{ entreprise.adresse }}{% if entreprise.codePostal or entreprise.ville %} — {{ entreprise.codePostal }} {{ entreprise.ville }}{% endif %}<br>
                {% if entreprise.telephone %}Tél : {{ entreprise.telephone }}{% if entreprise.email %} &nbsp;|&nbsp; {% endif %}{% endif %}
                {% if entreprise.email %}{{ entreprise.email }}{% endif %}
                {% if entreprise.siteWeb %}<br>{{ entreprise.siteWeb }}{% endif %}
            </div>
        </div>
        <div class="header-right">
            {% block header_right %}{% endblock %}
        </div>
    </div>

    {# ===== CORPS DU DOCUMENT ===== #}
    {% block content %}{% endblock %}

    {# ===== CONDITIONS & SIGNATURE ===== #}
    {% block conditions %}
    <div class="conditions-section">
        <div class="conditions-left">
            <strong>Validité de l'offre :</strong> {{ entreprise.validiteOffre ?? '30 jours' }}<br>
            <strong>Délai d'exécution :</strong> {{ entreprise.delaiExecution ?? 'À convenir' }}<br>
            <strong>Mode de règlement :</strong> {{ entreprise.modeReglement ?? 'Selon conditions générales' }}
        </div>
        <div class="conditions-right">
            <div class="signature-box">
                <p>Bon pour accord</p>
                <p>Date et signature :</p>
                <br><br><br>
            </div>
        </div>
    </div>
    {% endblock %}

    {# ===== FOOTER ===== #}
    <div class="footer">
        {% if entreprise.banque or entreprise.iban %}
        <div class="footer-iban">
            <strong>Coordonnées bancaires :</strong>
            {% if entreprise.banque %}{{ entreprise.banque }}{% endif %}
            {% if entreprise.iban %}&nbsp;| IBAN : {{ entreprise.iban }}{% endif %}
            {% if entreprise.bic %}&nbsp;| BIC : {{ entreprise.bic }}{% endif %}
        </div>
        {% endif %}
        <div class="mentions-legales">
            {{ entreprise.nom }}
            {% if entreprise.formeJuridique %} {{ entreprise.formeJuridique }}{% endif %}
            {% if entreprise.capital %} au Capital de {{ entreprise.capital }}{% endif %}
            {% if entreprise.siret %} — SIRET : {{ entreprise.siret }}{% endif %}
            {% if entreprise.rcs and entreprise.villeRcs %} — RCS {{ entreprise.villeRcs }}{% endif %}
            {% if entreprise.tvaIntracommunautaire %} — TVA : {{ entreprise.tvaIntracommunautaire }}{% endif %}
            {% if entreprise.codeNaf %} — NAF : {{ entreprise.codeNaf }}{% endif %}
        </div>
    </div>

</body>
</html>
